# Database
DATABASE_URL="postgresql://postgres:123456@localhost:5432/memory_bloom?schema=public"

# JWT
JWT_SECRET="seu-jwt-secret-super-seguro-aqui"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL="http://memorybloom-front.s3-website.us-east-2.amazonaws.com"

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Spotify (para busca de músicas em /criar)
# Obtenha em: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Email (para magic link)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@memorybloom.com"

# Upload (opcional - para S3/R2)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_BUCKET_NAME=""
# AWS_ENDPOINT="" # Para Cloudflare R2

# Stripe (opcional)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# Mercado Pago (Pix + Checkout Transparente)
# Produção: use APP_USR-... | Teste: use TEST-... (troque em desenvolvimento)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-7687199113594925-020820-7aaa9ce3e447a295f8a9396c0af27d25-2637229598
# Chave pública - necessária para pagamento com cartão (Checkout Transparente)
